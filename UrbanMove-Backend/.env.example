# Configuration serveur
PORT=5000
NODE_ENV=development

# Base de données MongoDB
MONGODB_URI=mongodb://localhost:27017/urbanmove
# Pour MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.xxxxx.mongodb.net/urbanmove

# JWT Secret - Changez cette clé en production!
JWT_SECRET=urbanmove_secret_key_change_in_production_2026
JWT_EXPIRES_IN=7d

# URLs autorisées (CORS)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# API Keys (pour services externes)
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# STRIPE_SECRET_KEY=your_stripe_secret_key
